[Unit]
Description=Solar Cloudflare Tunnel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=server
Group=server
WorkingDirectory=/home/server
ExecStart=/usr/local/bin/cloudflared tunnel --config /home/server/.cloudflared/config.yml run onewordtext
Restart=always
RestartSec=5
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
